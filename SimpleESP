-- [[ OMNI-GOD ESP CORE + TEAM COLOR ]]
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local ESP_SETTINGS = {
	Enabled = false,
	BoxColor = Color3.fromRGB(0, 255, 255), -- Màu khung giữ nguyên Cyan cho chuyên nghiệp
	DefaultTextColor = Color3.fromRGB(255, 255, 255),
	TextSize = 16
}

local function CreateESP(player)
	local Box = Drawing.new("Square")
	Box.Visible = false
	Box.Color = ESP_SETTINGS.BoxColor
	Box.Thickness = 1
	Box.Transparency = 1
	Box.Filled = false

	local NameTag = Drawing.new("Text")
	NameTag.Visible = false
	NameTag.Center = true
	NameTag.Outline = true
	NameTag.Size = ESP_SETTINGS.TextSize

	local function Update()
		local Connection
		Connection = RunService.RenderStepped:Connect(function()
			if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player ~= LocalPlayer then
				local RootPart = player.Character.HumanoidRootPart
				local Head = player.Character:FindFirstChild("Head")

				if Head then
					local RootPos, OnScreen = Camera:WorldToViewportPoint(RootPart.Position)
					local HeadPos = Camera:WorldToViewportPoint(Head.Position + Vector3.new(0, 0.6, 0))
					local LegPos = Camera:WorldToViewportPoint(RootPart.Position - Vector3.new(0, 3.3, 0))

					if OnScreen and ESP_SETTINGS.Enabled then
						-- 1. Cập nhật Khung (Box) áp sát
						local BoxHeight = math.abs(HeadPos.Y - LegPos.Y)
						local BoxWidth = BoxHeight / 1.8

						Box.Size = Vector2.new(BoxWidth, BoxHeight)
						Box.Position = Vector2.new(RootPos.X - BoxWidth / 2, RootPos.Y - BoxHeight / 2)
						Box.Visible = true

						-- 2. Xử lý Team & Màu sắc
						local TeamName = player.Team and player.Team.Name or "No Team"
						local TeamColor = player.TeamColor and player.TeamColor.Color or ESP_SETTINGS.DefaultTextColor

						-- 3. Cập nhật Text (Tên | Team | Khoảng cách)
						local Distance = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - RootPart.Position).Magnitude)
						NameTag.Text = string.format("%s [%s]\n%d studs", player.Name, TeamName, Distance)
						NameTag.Color = TeamColor -- Màu chữ theo màu Team
						NameTag.Position = Vector2.new(RootPos.X, RootPos.Y - BoxHeight / 2 - 30)
						NameTag.Visible = true
					else
						Box.Visible = false
						NameTag.Visible = false
					end
				end
			else
				Box.Visible = false
				NameTag.Visible = false
				if not player.Parent then
					Box:Remove()
					NameTag:Remove()
					Connection:Disconnect()
				end
			end
		end)
	end
	coroutine.wrap(Update)()
end

-- Khởi tạo ban đầu
for _, player in pairs(Players:GetPlayers()) do
	CreateESP(player)
end
Players.PlayerAdded:Connect(CreateESP)

