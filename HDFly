local function refreshFlyState()
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChild("Humanoid")

	if stats.flying and hrp and hum then
		local bv = hrp:FindFirstChild("FlyVel") or Instance.new("BodyVelocity")
		bv.Name = "FlyVel"
		bv.MaxForce = Vector3.new(1, 1, 1) * math.huge
		bv.Velocity = Vector3.new(0, 0.1, 0)
		bv.Parent = hrp

		local bg = hrp:FindFirstChild("FlyGyro") or Instance.new("BodyGyro")
		bg.Name = "FlyGyro"
		bg.MaxTorque = Vector3.new(1, 1, 1) * math.huge
		bg.CFrame = workspace.CurrentCamera.CFrame
		bg.Parent = hrp
		hum.PlatformStand = true
	else
		if hrp then
			if hrp:FindFirstChild("FlyVel") then hrp.FlyVel:Destroy() end
			if hrp:FindFirstChild("FlyGyro") then hrp.FlyGyro:Destroy() end
		end
		if hum then
			hum.PlatformStand = false
			hum:ChangeState(Enum.HumanoidStateType.GettingUp)
		end
	end
end

-- 2. HÀM TOGGLE (Dùng chung cho UI và Phím tắt)
local function toggleFly()
	stats.flying = not stats.flying

	-- Cập nhật UI
	if StatusText then StatusText.Text = stats.flying and "DISABLE" or "ENABLE" end
	if Indicator then 
		Indicator.Text = stats.flying and "ON" or "OFF"
		Indicator.TextColor3 = stats.flying and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
	end

	refreshFlyState()
end

-- 3. KẾT NỐI SỰ KIỆN
ChangeStatus.MouseButton1Click:Connect(toggleFly)

UserInputService.InputBegan:Connect(function(input, processed)
	if not processed and input.KeyCode == Enum.KeyCode.E then
		toggleFly()
	end
end)

-- UI Toggle Logic
Minimise.MouseButton1Click:Connect(function()
	stats.isOpen = not stats.isOpen
	if stats.isOpen then
		MainFrame.Visible = true
		MiniText.Text = "-"
		TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(1, 0, 1, 0)}):Play()
	else
		MiniText.Text = "+"
		local closeTween = TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(1, 0, 0, 0)})
		closeTween.Completed:Connect(function()
			if not stats.isOpen then MainFrame.Visible = false end
		end)
		closeTween:Play()
	end
end)

-- Speed Sync
TextBox.FocusLost:Connect(function()
	local n = tonumber(TextBox.Text)
	stats.flySpeed = n or stats.flySpeed
	TextBox.Text = tostring(stats.flySpeed)
end)

-- Thêm biến kiểm tra thiết bị di động
local GuiService = game:GetService("GuiService")

-- Biến tạm để kiểm tra trạng thái phím cho Mobile & PC
local ControlModule = {
	forward = 0, backward = 0, left = 0, right = 0, up = 0, down = 0
}

-- Hàm cập nhật vận tốc cực kỳ chính xác
local function getDirection()
	local camera = workspace.CurrentCamera
	local moveDir = LocalPlayer.Character.Humanoid.MoveDirection

	-- Nếu không có input di chuyển
	if moveDir.Magnitude == 0 then
		return Vector3.new(0, 0, 0)
	end

	-- Tính toán hướng dựa trên Camera (Bao gồm cả trục Y khi nhìn lên/xuống)
	local lookVec = camera.CFrame.LookVector
	local rightVec = camera.CFrame.RightVector

	-- Tính toán độ lệch hướng
	local forward = moveDir:Dot(camera.CFrame.LookVector)
	local side = moveDir:Dot(camera.CFrame.RightVector)

	return (lookVec * forward + rightVec * side).Unit
end

RunService.Heartbeat:Connect(function(dt)
	local char = LocalPlayer.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChild("Humanoid")
	local camera = workspace.CurrentCamera

	if stats.flying and hrp and hum then
		local flyVel = hrp:FindFirstChild("FlyVel")
		local flyGyro = hrp:FindFirstChild("FlyGyro")

		if flyVel and flyGyro then
			-- 1. Giữ góc xoay theo Camera
			flyGyro.CFrame = camera.CFrame

			-- 2. Lấy hướng bay từ Joystick/WASD
			local dir = getDirection()

			-- 3. Xử lý bay lên/xuống thủ công (Space/Ctrl)
			local vertical = 0
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vertical = 1 end
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then vertical = -1 end

			-- 4. TÍNH TOÁN VẬN TỐC CUỐI CÙNG
			local finalVel = Vector3.new(0, 0, 0)

			if dir.Magnitude > 0 or vertical ~= 0 then
				-- Nếu có di chuyển: Áp dụng lực
				finalVel = (dir * stats.flySpeed) + Vector3.new(0, vertical * stats.flySpeed, 0)
				flyVel.Velocity = finalVel
			else
				-- 5. FIX TRÔI TUYỆT ĐỐI (FORCE ANCHOR)
				flyVel.Velocity = Vector3.new(0, 0, 0)
				-- Ép cứng vận tốc vật lý của khối HRP về 0 để không bị quán tính trôi
				hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
			end
		end
	end
end)
