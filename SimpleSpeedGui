-- 1. HỆ THỐNG KÉO THẢ SIÊU MƯỢT (FIX LỆCH)
-----------------------------------------
local dragging, dragStart, startPositions = false, nil, {}

local function UpdateGuiPosition(input)
	local delta = input.Position - dragStart
	for object, startPos in pairs(startPositions) do
		object.Position = UDim2.new(
			startPos.X.Scale, 
			startPos.X.Offset + delta.X, 
			startPos.Y.Scale, 
			startPos.Y.Offset + delta.Y
		)
	end
end

Name.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position

		-- Chụp vị trí của cả 3 phần để di chuyển đồng bộ
		startPositions = {
			[Name] = Name.Position,
			[Main] = Main.Position,
			[TextButton_3] = TextButton_3.Position
		}

		local connection
		connection = UserInputService.InputEnded:Connect(function(ReleasedInput)
			if ReleasedInput.UserInputType == Enum.UserInputType.MouseButton1 or ReleasedInput.UserInputType == Enum.UserInputType.Touch then
				dragging = false
				connection:Disconnect()
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		UpdateGuiPosition(input)
	end
end)

