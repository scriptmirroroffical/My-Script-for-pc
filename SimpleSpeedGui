local function SetFriction(character)
	for _, part in pairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			-- Tăng độ bám đường lên mức tối đa
			part.CustomPhysicalProperties = PhysicalProperties.new(100, 0.3, 0.5, 100, 100)
		end
	end
end

TextButton.MouseButton1Click:Connect(function()
	local char = Player.Character
	if char and char:FindFirstChild("Humanoid") then
		char.Humanoid.WalkSpeed = tonumber(TextBox.Text) or 16
		SetFriction(char)
	end
end)

TextButton_2.MouseButton1Click:Connect(function()
	isSpamming = not isSpamming
	TextButton_2.Text = isSpamming and "SPAM: ON" or "SPAM SET"
